# copilot-bridge connection
BRIDGE_API_URL=http://127.0.0.1:7878
BRIDGE_API_KEY=your-bridge-http-api-key-here

# Public base URL for this kanban server, used by bridge push callbacks
KANBAN_BASE_URL=http://127.0.0.1:3000

# Session encryption secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=change-me-to-a-random-hex-string

# SQLite database path
DB_PATH=./data/kanban.db

# Server port
PORT=3000

# Log level (fatal, error, warn, info, debug, trace, silent)
# LOG_LEVEL=info
