{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/client/*"]
    },
    "outDir": "dist/client",
    "rootDir": "src/client",
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/client/**/*"]
}
